{
    "manifest_version": 3,
    "name": "ChatGPT PRepo",
    "version": "1.4",
    "description": "A repository replete with ChatGPT prompts",
    "permissions": [
        "storage",
        "activeTab",
        "webNavigation",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon.png",
            "48": "icon.png",
            "128": "icon.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://chat.openai.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "icons": {
        "48": "icon.png",
        "96": "icon.png"
    }
}